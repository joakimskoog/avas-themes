{
  "manifest_version": 3,
  "name": "Ava's Themes",
  "description": "An unofficial browser extension that adds beautiful, community-loved themes to Avanza.",
  "version": "0.1.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.avanza.se/*"],
      "js": ["assets/content.js"],
      "run_at": "document_start"
    }
  ]
}
